{
  "name": "pruthviraj-monorepo",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=client\" \"npm run start --workspace=server\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run start --workspace=server",
    "build": "npm run build --workspace=client",
    "seed": "npm run seed --workspace=server",
    "seed:admins": "npm run seed:admins --workspace=server",
    "seed:users": "npm run seed:users --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
